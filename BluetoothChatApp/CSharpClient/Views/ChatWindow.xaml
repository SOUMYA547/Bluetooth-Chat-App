<Window x:Class="BluetoothChatApp.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat" Height="420" Width="520">
  <DockPanel Margin="8">
    <ScrollViewer DockPanel.Dock="Top" Height="280">
      <TextBlock Text="{Binding ChatLog}" TextWrapping="Wrap"/>
    </ScrollViewer>
    <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom">
      <TextBox Text="{Binding Outgoing, UpdateSourceTrigger=PropertyChanged}" Width="400" Height="32" Margin="0,6,6,0"/>
      <Button Content="Send" Command="{Binding SendCommand}" Width="80" Height="32"/>
    </StackPanel>
  </DockPanel>
</Window>
