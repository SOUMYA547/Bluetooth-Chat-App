<Window x:Class="BluetoothChatApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="260" Width="420">
  <StackPanel Margin="12">
    <TextBlock Text="Account Name" />
    <TextBox Text="{Binding AccountName}" />
    <TextBlock Text="Avatar Path" Margin="0,8,0,0"/>
    <TextBox Text="{Binding AvatarPath}" />
    <CheckBox Content="Dark Mode" IsChecked="{Binding DarkMode}" Margin="0,8,0,0"/>
    <Button Content="Save" Margin="0,8,0,0" Command="{Binding SaveCommand}"/>
  </StackPanel>
</Window>
