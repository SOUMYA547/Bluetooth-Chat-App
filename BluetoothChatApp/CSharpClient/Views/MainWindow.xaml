<Window x:Class="BluetoothChatApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Bluetooth Chat" Height="560" Width="900"
        Loaded="Window_Loaded">
  <Grid Margin="10">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*"/>
      <ColumnDefinition Width="3*"/>
    </Grid.ColumnDefinitions>

    <!-- Left: Controls -->
    <StackPanel>
      <TextBlock Text="Nearby (BLE/RFCOMM)" FontSize="18" Margin="0,0,0,8"/>
      <WrapPanel Margin="0,0,0,8" >
        <Button Name="ScanBleBtn" Content="Scan BLE" Height="32" Margin="0,0,8,0" Click="Scan_Click"/>
        <Button Name="ScanRfcommBtn" Content="Scan RFCOMM" Height="32" Click="Scan_Rfcomm_Click"/>
      </WrapPanel>
      <ListBox Name="DevicesList" DisplayMemberPath="Name" Height="350"/>
      <Button Content="Open Chat" Click="OpenChat_Click" />
      <Button Content="Settings" Margin="0,6,0,0" Click="Settings_Click"/>
    </StackPanel>

    <!-- Right: React UI hosted via WebView2 -->
    <Grid Grid.Column="1">
      <wv2:WebView2 x:Name="Web" Source="about:blank"/>
      <TextBlock Text="Loading UI..." HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
    </Grid>
  </Grid>
</Window>
